# Replace YOUR_IP with your machine's IP for network access from other machines.
# Copy this file to docker-compose.local-full.env and update the IP.
# Usage: docker compose -f docker-compose.local-full.yml --env-file docker-compose.local-full.env up -d
PUBLIC_HOST_URL=http://YOUR_IP:3001
PUBLIC_WS_URL=ws://YOUR_IP:8056/ws
PUBLIC_API_URL=http://YOUR_IP:8056
NEXTAUTH_URL=http://YOUR_IP:3001
DECISION_LISTENER_URL=http://YOUR_IP:8766
